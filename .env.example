# Supabase (fresh project for the rebuild - never reuse hackathon keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Service role key: used ONLY by seed script and CI. Never in app code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Synthetic test users for the RLS security test (pnpm db:security-test).
# Created server side by the seed; passwords live only in .env.local and CI secrets.
TEST_RIDER_A_EMAIL=rider.a.test@example.com
TEST_RIDER_A_PASSWORD=YOUR_TEST_PASSWORD
TEST_RIDER_B_EMAIL=rider.b.test@example.com
TEST_RIDER_B_PASSWORD=YOUR_TEST_PASSWORD
TEST_CONDUCTOR_EMAIL=conductor.test@example.com
TEST_CONDUCTOR_PASSWORD=YOUR_TEST_PASSWORD

# Demo users for rehearsal (pnpm db:seed, pnpm auth:verify). Created server side
# with email+password so rehearsal and CI sign in without an SMS provider; each
# also carries a phone number for when phone OTP goes live. Passwords live only
# in .env.local and CI secrets.
DEMO_RIDER_EMAIL=demo.rider@svika.app
DEMO_RIDER_PHONE=+263770000001
DEMO_RIDER_PASSWORD=YOUR_DEMO_PASSWORD
DEMO_OWNER_EMAIL=demo.owner@svika.app
DEMO_OWNER_PHONE=+263770000002
DEMO_OWNER_PASSWORD=YOUR_DEMO_PASSWORD
DEMO_CONDUCTOR_EMAIL=demo.conductor@svika.app
DEMO_CONDUCTOR_PHONE=+263770000003
DEMO_CONDUCTOR_PASSWORD=YOUR_DEMO_PASSWORD

# Demo door (landing page): the pooled judge personas share one password.
# Used by the seed to create the pool and by the web server to sign a judge
# in after claim_demo_persona; never sent to the browser. Story mode also
# signs in the demo conductor server side (creds above) to play the hwindi.
DEMO_JUDGE_PASSWORD=YOUR_DEMO_PASSWORD

# Maps: the raw MapTiler API key (not a full URL). The app builds the style
# URL itself and repaints the base style to Brand v2 at load.
NEXT_PUBLIC_MAP_TILES_URL=

# Text AI (adapter has a mock twin; app runs without this)
GEMINI_API_KEY=
AI_PROVIDER=mock

# Spine service (services/spine, pnpm --filter @svika/spine dev). When set,
# the home screen's arrival estimates come from GET /eta (real numbers from
# recorded rides); when unset or unreachable, the mock twin serves and the
# label says demo estimate. In a deploy this points at the Render spine URL
# (see docs/DEPLOY.md); leaving it empty is safe and falls back to the twin.
SPINE_URL=http://127.0.0.1:8787

# Voice assets are pre-generated and cached in-repo under apps/web/public/voice.
# ElevenLabs is a studio tool, not a runtime dependency. No key needed at runtime.

# e2e only: enables the test login endpoint (apps/web/src/app/e2e/login).
# Set by the Playwright web server config for local/CI runs. NEVER set in a deploy.
# E2E_AUTH=on
