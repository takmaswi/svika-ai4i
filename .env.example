# Supabase (fresh project for the rebuild - never reuse hackathon keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Service role key: used ONLY by seed script and CI. Never in app code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Synthetic test users for the RLS security test (pnpm db:security-test).
# Created server side by the seed; passwords live only in .env.local and CI secrets.
TEST_RIDER_A_EMAIL=rider.a.test@example.com
TEST_RIDER_A_PASSWORD=YOUR_TEST_PASSWORD
TEST_RIDER_B_EMAIL=rider.b.test@example.com
TEST_RIDER_B_PASSWORD=YOUR_TEST_PASSWORD
TEST_CONDUCTOR_EMAIL=conductor.test@