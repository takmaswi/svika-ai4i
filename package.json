{
  "name": "svika",
  "private": true,
  "version": "0.1.0",
  "description": "Digital ticketing and trip intelligence for Harare's informal kombi network.",
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter web test:e2e",
    "build": "pnpm -r --if-present build",
    "db:security-test": "pnpm --filter @svika/db security-test",
    "db:seed": "pnpm --filter @svika/db seed",
    "auth:verify": "pnpm --filter web auth:verify",
    "db:ledger-test": "pnpm --filter @svika/db ledger-test",
    "db:offline-test": "pnpm --filter @svika/db offline-test",
    "spine:ingest": "pnpm --filter @svika/spine ingest",
    "spine:train": "pnpm --filter @svika/spine train"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "eslint": "9.18.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}
