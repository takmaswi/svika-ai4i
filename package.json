{
  "name": "svika",
  "private": true,
  "version": "0.1.0",
  "description": "Digital ticketing and trip intelligence for Harare's informal kombi network.",
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter web test:e2e",
    "db:security-test": "pnpm --filter @svika/db security-test"
  },
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9.15.0"
}
